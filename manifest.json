{
  "manifest_version": 3,
  "name": "极简录屏 Screen Recorder",
  "version": "1.0.0",
  "description": "本地零依赖录屏：屏幕/窗口/标签页 + 系统声音/麦克风，摄像头画中画、区域、画笔、仅录摄像头，导出 webm/mp4。Local screen recorder.",
  "permissions": ["tabs", "storage"],
  "background": { "service_worker": "background.js" },
  "commands": {
    "stop-recording": {
      "suggested_key": { "default": "Ctrl+Shift+S", "mac": "Command+Shift+S" },
      "description": "停止录制"
    },
    "pause-recording": {
      "suggested_key": { "default": "Ctrl+Shift+U", "mac": "Command+Shift+U" },
      "description": "暂停/继续录制"
    }
  },
  "action": {
    "default_title": "极简录屏",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
